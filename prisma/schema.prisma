generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Quest {
  id           String    @id @default(uuid())
  title        String
  category     String    
  status       String    
  
  dateText     String    
  location     String?   
  image        String?   
  
  capacity     Int       @default(30)
  seatsTaken   Int       @default(0)
  
  targetDate   DateTime? 
  endDate      DateTime? 
  
  price        Float     @default(0)
  upiLink      String?
  
  recapUrl     String?  

  registrations Registration[]
  ratings       QuestRating[]

  createdAt    DateTime  @default(now())
}

model Game {
  id              String   @id @default(uuid())
  title           String
  description     String
  engine          String   @default("Custom") // e.g., "Unity", "Godot", "Web", "Custom"
  genre           String   // e.g., "Racing", "Puzzle", "Thriller"
  dimension       String?  // e.g., "2D", "3D"
  duration        String?  // e.g., "2h"
  year            String?  // e.g., "2024", "2025"
  coverUrl        String?  // Image URL
  playUrl         String?  // Link to the game site
  developer       String
  isEditorsChoice Boolean  @default(false)
  createdAt       DateTime @default(now())
}


model TeamMember {
  id          String     @id @default(uuid())
  name        String
  role        String
  avatar      String?
  department  String
  stats       Json?
  gamePreview Json?
  createdAt   DateTime   @default(now())
}

model Leaderboard {
  id        String   @id @default(uuid())
  rank      Int
  player    String
  score     Float
  gameTitle String
  date      String
  createdAt DateTime @default(now())
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  phone        String
  fullName     String
  rollNo       String
  academicYear String
  tools        String[]
  xpLevel      String
  
  registrations Registration[]
  ratings       QuestRating[]
  
  createdAt    DateTime  @default(now())
}

model Registration {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId   String
  quest     Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  status    String   // "PENDING", "REGISTERED"
  upiRef    String?
  createdAt DateTime @default(now())
  
  @@unique([userId, questId])
}

model QuestRating {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId   String
  quest     Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  rating    Int
  createdAt DateTime @default(now())
  
  @@unique([userId, questId])
}

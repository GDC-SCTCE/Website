generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Quest {
  id           String    @id @default(uuid())
  title        String
  category     String    
  status       String    
  
  dateText     String    
  location     String?   
  image        String?   
  
  capacity     Int       @default(30)
  seatsTaken   Int       @default(0)
  
  targetDate   DateTime? 

  attendees    Int?      
  rating       Float?    
  recapUrl     String?  

  createdAt    DateTime  @default(now())
}

model Game {
  id          String        @id @default(uuid())
  title       String
  description String
  genre       String
  developer   String
  rating      Float?
  coverUrl    String?
  releaseYear String?
  features    String[]
  playable    Boolean       @default(false)
  highScores  GameHighScore[]
  createdAt   DateTime      @default(now())
}

model GameHighScore {
  id        String   @id @default(uuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player    String
  score     Float
  date      String
  createdAt DateTime @default(now())
}



model TeamMember {
  id          String     @id @default(uuid())
  name        String
  role        String
  avatar      String?
  department  String
  stats       Json?
  gamePreview Json?
  createdAt   DateTime   @default(now())
}

model Leaderboard {
  id        String   @id @default(uuid())
  rank      Int
  player    String
  score     Float
  gameTitle String
  date      String
  createdAt DateTime @default(now())
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum XPLevel {
  Newbie
  Apprentice
  Veteran
}

enum Department {
  ALL
  DESIGN
  TECH
  MEDIA
  COMMUNITY
  EVENT
  MARKETING
  E_SPORTS @map("E-SPORTS")
}

enum QuestCategory {
  Workshops
  Game_Jams @map("Game Jams")
  Talks
}

enum QuestStatus {
  UPCOMING
  ACTIVE
  COMPLETED
}

enum RegistrationStatus {
  PENDING
  REGISTERED
  ATTENDED
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  phone        String
  fullName     String
  rollNo       String
  academicYear String
  tools        String[]
  xpLevel      XPLevel @default(Newbie)
  
  registrations Registration[]
  ratings       QuestRating[]
  
  createdAt    DateTime  @default(now())
}

model TeamMember {
  id          String     @id @default(uuid())
  name        String
  role        String
  avatar      String?
  department  Department
  stats       Json?
  gamePreview Json?
  createdAt   DateTime   @default(now())
}

model Quest {
  id           String    @id @default(uuid())
  title        String
  category     QuestCategory    
  status       QuestStatus    
  
  dateText     String    
  location     String?   
  image        String?   
  
  capacity     Int       @default(30)
  seatsTaken   Int       @default(0)
  
  targetDate   DateTime? 
  endDate      DateTime? 
  
  price        Float     @default(0)
  upiLink      String?
  
  recapUrl     String?  

  registrations Registration[]
  ratings       QuestRating[]

  createdAt    DateTime  @default(now())
}

model QuestRating {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId   String
  quest     Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  rating    Int
  createdAt DateTime @default(now())
  
  @@unique([userId, questId])
}

model Registration {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questId   String
  quest     Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  status    RegistrationStatus   // "PENDING", "REGISTERED", "ATTENDED"
  upiRef    String?
  createdAt DateTime @default(now())
  
  @@unique([userId, questId])
}

model Game {
  id              String   @id @default(uuid())
  title           String
  description     String
  engine          String   @default("Custom") // e.g., "Unity", "Godot", "Web", "Custom"
  genre           String   // e.g., "Racing", "Puzzle", "Thriller"
  dimension       String?  // e.g., "2D", "3D"
  duration        String?  // e.g., "2h"
  year            String?  // e.g., "2024", "2025"
  coverUrl        String?  // Image URL
  playUrl         String?  // Link to the game site
  developer       String
  isEditorsChoice Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model Leaderboard {
  id        String   @id @default(uuid())
  rank      Int
  player    String
  score     Float
  gameTitle String
  date      String
  createdAt DateTime @default(now())
}

enum ToolCategory {
  ENGINES
  ART
  AUDIO
  COLLAB
  LEARNING
}

enum ToolPricing {
  FREE
  FREEMIUM
  PAID
}

model Tool {
  id          String       @id @default(uuid())
  name        String       @unique
  category    ToolCategory
  rating      Int          @default(5)
  pricing     ToolPricing  @default(FREE)
  platforms   String
  description String
  url         String
  iconUrl     String?       // URL to the tool's logo/icon in Supabase Storage

  createdAt   DateTime     @default(now())
}
